# Supabase (already set)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry — get DSN from sentry.io > Project > Settings > Client Keys
VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/xxx

# PostHog — get from posthog.com > Project Settings > Project API Key
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Resend — set this in Supabase Dashboard > Edge Functions > Secrets (NOT in Vercel)
# Get from resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# PayDunya — set ALL of these in Supabase Dashboard > Edge Functions > Secrets (NOT in Vercel)
# Get from app.paydunya.com > Setup > API Keys
PAYDUNYA_MASTER_KEY=your-master-key
PAYDUNYA_PRIVATE_KEY=your-private-key
PAYDUNYA_TOKEN=your-token
# Set to "test" during development, "live" for production
PAYDUNYA_MODE=live
